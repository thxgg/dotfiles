#!/usr/bin/env zsh

set -euo pipefail

# Resolve this script even when invoked through ~/.local/bin/dot.
script_path="$0"
while [[ -L "$script_path" ]]; do
	link_target="$(readlink "$script_path")"
	if [[ "$link_target" == /* ]]; then
		script_path="$link_target"
	else
		script_path="${script_path:h}/$link_target"
	fi
done

DOTFILES_DIR="${script_path:A:h}"
SCRIPT_NAME="dot"
VERSION="0.1.0"

RED=$'\033[0;31m'
GREEN=$'\033[0;32m'
YELLOW=$'\033[0;33m'
BLUE=$'\033[0;34m'
CYAN=$'\033[0;36m'
BOLD=$'\033[1m'
RESET=$'\033[0m'

UPDATE_VERBOSE=0

info() {
	printf "${CYAN}[INFO]${RESET} %s\n" "$1"
}

success() {
	printf "${GREEN}[OK]${RESET} %s\n" "$1"
}

warn() {
	printf "${YELLOW}[WARN]${RESET} %s\n" "$1"
}

error() {
	printf "${RED}[ERROR]${RESET} %s\n" "$1" >&2
}

header() {
	printf "\n${BOLD}${BLUE}==>${RESET} ${BOLD}%s${RESET}\n" "$1"
}

command_exists() {
	command -v "$1" >/dev/null 2>&1
}

confirm() {
	local prompt="${1:-Continue?}"
	local default="${2:-n}"
	local response suffix

	if [[ "$default" == "y" ]]; then
		suffix='[Y/n]'
	else
		suffix='[y/N]'
	fi

	if [[ ! -t 0 || ! -t 1 ]]; then
		[[ "$default" == "y" ]]
		return
	fi

	printf '%s %s ' "$prompt" "$suffix"
	read -r response
	case "$response" in
		[yY]|[yY][eE][sS]) return 0 ;;
		[nN]|[nN][oO]) return 1 ;;
		'') [[ "$default" == "y" ]] ;;
		*) return 1 ;;
	esac
}

run_repo_script() {
	local script_name="$1"
	shift
	local script_path="$DOTFILES_DIR/$script_name"

	if [[ ! -f "$script_path" ]]; then
		error "Required script not found: $script_path"
		return 1
	fi

	zsh "$script_path" "$@"
}

usage() {
	cat <<EOF
${BOLD}${SCRIPT_NAME}${RESET} - Dotfiles management tool
Version: ${VERSION}

${BOLD}USAGE:${RESET}
    ${SCRIPT_NAME} [OPTIONS] COMMAND [ARGS]

${BOLD}COMMANDS:${RESET}
    init              Run full machine setup via ./setup.sh
    update            Pull latest repo changes, update packages, Neovim, stow, pi, Herdr, and pi extensions
    stow              Apply links via ./safe-stow.sh
    unstow            Remove links via ./unstow.sh
    doctor            Validate symlinks and setup health via ./doctor.sh
    check-packages    Check OS package manifest installation status
    package list      List package manifests
    benchmark-shell   Benchmark Fish shell startup time
    completions       Generate Fish shell completions for dot
    edit              Open this repo in \$EDITOR
    link              Symlink dot into ~/.local/bin (normally automatic)
    unlink            Remove dot symlinks from common PATH locations
    help              Show this help

${BOLD}OPTIONS:${RESET}
    --version         Show version information
    -h, --help        Show this help

${BOLD}UPDATE OPTIONS:${RESET}
    -v, --verbose     Stream full output from every update tool

${BOLD}EXAMPLES:${RESET}
    ${SCRIPT_NAME} init --skip-network-check
    ${SCRIPT_NAME} stow --only-config nvim,ghostty
    ${SCRIPT_NAME} doctor --only-config nvim
    ${SCRIPT_NAME} update --skip-packages
    ${SCRIPT_NAME} check-packages
    ${SCRIPT_NAME} package list linux
EOF
}

cmd_init() {
	header "Initializing dotfiles"
	run_repo_script setup.sh "$@"
}

cmd_stow() {
	header "Applying stow links"
	run_repo_script safe-stow.sh "$@"
}

cmd_unstow() {
	header "Removing stow links"
	run_repo_script unstow.sh "$@"
}

cmd_doctor() {
	header "Running dotfiles doctor"
	run_repo_script doctor.sh "$@"
}

cmd_edit() {
	local editor="${EDITOR:-nvim}"

	if ! command_exists "$editor"; then
		error "Editor not found: $editor"
		return 1
	fi

	exec "$editor" "$DOTFILES_DIR"
}

cmd_link() {
	header "Installing dot command"

	local target_dir="${DOTFILES_BIN_DIR:-$HOME/.local/bin}"
	local link_path="$target_dir/dot"
	mkdir -p "$target_dir"

	if [[ -e "$link_path" && ! -L "$link_path" ]]; then
		error "Refusing to replace non-symlink: $link_path"
		return 1
	fi

	ln -sfn "$DOTFILES_DIR/dot" "$link_path"
	success "Linked $link_path -> $DOTFILES_DIR/dot"

	case ":$PATH:" in
		*":$target_dir:"*) success "$target_dir is already in PATH" ;;
		*) warn "$target_dir is not in PATH" ;;
	esac
}

cmd_unlink() {
	header "Uninstalling dot command"

	local paths=(
		"$HOME/.local/bin/dot"
		"/usr/local/bin/dot"
		"/opt/homebrew/bin/dot"
	)
	local removed=0 path

	for path in "${paths[@]}"; do
		if [[ -L "$path" ]]; then
			rm "$path"
			success "Removed $path"
			removed=1
		fi
	done

	if [[ $removed -eq 0 ]]; then
		warn "No dot symlink found"
	fi
}

update_repo() {
	header "Updating repository"

	if [[ -d "$DOTFILES_DIR/.jj" ]] && command_exists jj; then
		info "Detected jj-managed repository"
		jj git fetch -R "$DOTFILES_DIR" || return
		jj -R "$DOTFILES_DIR" rebase -d 'trunk()' || return
		success "Repository updated with jj"
		return
	fi

	if ! git -C "$DOTFILES_DIR" rev-parse --git-dir >/dev/null 2>&1; then
		warn "Not a git repository; skipping pull"
		return
	fi

	git -C "$DOTFILES_DIR" pull --ff-only || return
	success "Repository updated with git"
}

update_packages() {
	header "Updating OS packages"

	case "$OSTYPE" in
		darwin*)
			if ! command_exists brew; then
				warn "Homebrew not found; skipping package update"
				return
			fi

			brew update || return
			brew upgrade || return
			if [[ -f "$DOTFILES_DIR/macos/Brewfile" ]]; then
				brew bundle --file="$DOTFILES_DIR/macos/Brewfile" || return
			fi
			brew cleanup || return
			;;
		linux-gnu*)
			if command_exists yay; then
				yay -Syu --needed || return
			elif command_exists pacman; then
				warn "yay not found; using pacman for repo packages only"
				sudo pacman -Syu || return
			else
				warn "No supported Linux package manager found; skipping package update"
				return
			fi
			;;
		*)
			warn "Unsupported OSTYPE for package update: $OSTYPE"
			return
			;;
	esac

	success "OS packages updated"
}

update_pi() {
	header "Updating pi and extensions"

	if ! command_exists pi; then
		warn "pi not found; skipping"
		return
	fi

	local pi_workspace="$DOTFILES_DIR/common/.pi"
	local vp_bin=""
	if command_exists vp; then
		vp_bin="$(command -v vp)"
	elif [[ -x "${VP_HOME:-$HOME/.vite-plus}/bin/vp" ]]; then
		vp_bin="${VP_HOME:-$HOME/.vite-plus}/bin/vp"
	else
		error "Vite+ not found; cannot install Pi extension dependencies"
		return 1
	fi
	if [[ ! -f "$pi_workspace/package-lock.json" ]]; then
		error "Pi extension lockfile is missing: $pi_workspace/package-lock.json"
		return 1
	fi

	info "Installing locked Pi extension dependencies"
	(cd "$pi_workspace" && "$vp_bin" install --frozen-lockfile) || return

	local -a pi_update_env
	pi_update_env=(env CARGO_NET_GIT_FETCH_WITH_CLI=true)

	# Cargo nightly 1.94 has a regression resolving glimpseui's SSH-style
	# gtk4-layer-shell submodule URL. Prefer stable when rustup has it.
	if command_exists rustup && rustup toolchain list 2>/dev/null | grep -q '^stable'; then
		pi_update_env+=(RUSTUP_TOOLCHAIN=stable)
	fi

	if (cd "$DOTFILES_DIR" && "${pi_update_env[@]}" pi update --help 2>&1 | grep -q -- '--extensions'); then
		info "Updating pi CLI"
		(cd "$DOTFILES_DIR" && "${pi_update_env[@]}" pi update --self) || return
		info "Updating pi extensions/packages"
		(cd "$DOTFILES_DIR" && "${pi_update_env[@]}" pi update --extensions) || return
	else
		warn "pi update --extensions not supported; falling back to legacy pi update"
		(cd "$DOTFILES_DIR" && "${pi_update_env[@]}" pi update) || return
	fi

	success "pi and extensions updated"
}

update_herdr() {
	header "Updating Herdr"

	if ! command_exists herdr; then
		warn "herdr not found; skipping"
		return
	fi

	# Homebrew installations disable Herdr's self-updater. Keep this step useful
	# when package updates are skipped or fail before reaching Herdr.
	if command_exists brew && brew list --formula herdr >/dev/null 2>&1; then
		info "Updating Homebrew-managed Herdr"
		brew upgrade herdr || return
	else
		local -a herdr_update_cmd
		herdr_update_cmd=(herdr update)
		if [[ -n "${HERDR_ENV:-}" ]]; then
			herdr_update_cmd+=(--handoff)
		fi

		"${herdr_update_cmd[@]}" || return
	fi

	success "Herdr updated"
}

update_nvim() {
	header "Updating Neovim plugins and tools"

	if ! command_exists nvim; then
		warn "nvim not found; skipping"
		return
	fi

	info "Updating, syncing, cleaning, and checking Lazy.nvim plugins"
	nvim --headless \
		"+Lazy! update" \
		"+Lazy! sync" \
		"+Lazy! clean" \
		"+Lazy! check" \
		+qa || return

	info "Updating Mason registries and installed packages"
	local mason_script mason_status
	mason_script="$(mktemp "${TMPDIR:-/tmp}/dot-mason-update.XXXXXX")"
	cat > "$mason_script" <<'LUA'
local ok_registry, registry = pcall(require, "mason-registry")
if not ok_registry then
	error("mason-registry unavailable: " .. tostring(registry))
end

local registry_done = false
local registry_success = false
registry.update(function(success)
	registry_success = success
	registry_done = true
end)

if not vim.wait(300000, function()
	return registry_done
end, 100) then
	error("Timed out updating Mason registries")
end

if not registry_success then
	error("Failed to update Mason registries")
end

local failures = {}
local pending = 0
local scheduled = 0

for _, pkg in ipairs(registry.get_installed_packages()) do
	local current = pkg:get_installed_version()
	local ok_latest, latest = pcall(function()
		return pkg:get_latest_version()
	end)
	local ok_installable, installable = pcall(function()
		return latest ~= nil and current ~= latest and pkg:is_installable({ version = latest })
	end)

	if ok_latest and ok_installable and installable then
		scheduled = scheduled + 1
		pending = pending + 1
		print(("Updating Mason package: %s (%s -> %s)"):format(pkg.name, tostring(current), tostring(latest)))
		local ok_install, install_err = pcall(function()
			pkg:install({ version = latest }, function(success, err)
				if not success then
					table.insert(failures, pkg.name .. ": " .. tostring(err))
				end
				pending = pending - 1
			end)
		end)
		if not ok_install then
			table.insert(failures, pkg.name .. ": " .. tostring(install_err))
			pending = pending - 1
		end
	elseif not ok_latest then
		table.insert(failures, pkg.name .. ": failed to determine latest version: " .. tostring(latest))
	elseif not ok_installable then
		table.insert(failures, pkg.name .. ": failed installability check: " .. tostring(installable))
	end
end

if pending > 0 and not vim.wait(1800000, function()
	return pending == 0
end, 500) then
	error("Timed out updating Mason packages")
end

if #failures > 0 then
	error("Mason package update failed:\n" .. table.concat(failures, "\n"))
end

if scheduled == 0 then
	print("All Mason packages are up-to-date")
else
	print(("Updated %d Mason package(s)"):format(scheduled))
end
LUA
	nvim --headless -c "luafile $mason_script" +qa
	mason_status=$?
	rm -f "$mason_script"
	if [[ $mason_status -ne 0 ]]; then
		return $mason_status
	fi

	info "Updating Tree-sitter parsers"
	nvim --headless "+lua require('nvim-treesitter').update():wait(300000)" +qa || return

	success "Neovim plugins and tools updated"
}

update_theme() {
	[[ "$OSTYPE" == darwin* && -x "$HOME/.local/bin/theme-mode" ]] || return 0
	header "Refreshing macOS theme mode"
	"$HOME/.local/bin/theme-mode" --quiet set auto
}

run_update_step() {
	local key="$1"
	local label="$2"
	local update_fn="$3"
	local log_file exit_status detail

	if [[ $UPDATE_VERBOSE -eq 1 ]]; then
		"$update_fn"
		return
	fi

	log_file="$(mktemp "${TMPDIR:-/tmp}/dot-update-${key}.XXXXXX")"
	"$update_fn" >"$log_file" 2>&1
	exit_status=$?
	if [[ $exit_status -eq 0 ]]; then
		if [[ "$key" == "repo" ]] && grep -q "Already up to date" "$log_file"; then
			success "$label already up to date"
		elif [[ "$key" == "packages" ]]; then
			detail="$(grep -Eo 'Upgraded [0-9]+ outdated packages' "$log_file" | tail -1 || true)"
			if [[ -n "$detail" ]]; then
				success "$label updated (${detail#Upgraded })"
			else
				success "$label updated"
			fi
		else
			success "$label updated"
		fi
		rm -f "$log_file"
		return 0
	fi

	error "$label update failed"
	if grep -Eiq '(^|[[:space:]])(error|failed|failure|refusing)(:|[[:space:]])' "$log_file"; then
		grep -Ei '(^|[[:space:]])(error|failed|failure|refusing)(:|[[:space:]])' "$log_file" | tail -12 >&2
	else
		tail -12 "$log_file" >&2
	fi
	warn "Re-run '${SCRIPT_NAME} update --verbose' for full output"
	rm -f "$log_file"
	return $exit_status
}

cmd_update() {
	local skip_packages=0
	local skip_stow=0
	local skip_pi=0
	local skip_herdr=0
	local skip_nvim=0
	local -a failed_steps=()

	while [[ $# -gt 0 ]]; do
		case "$1" in
			-v|--verbose)
				UPDATE_VERBOSE=1
				shift
				;;
			--skip-packages)
				skip_packages=1
				shift
				;;
			--skip-stow)
				skip_stow=1
				shift
				;;
			--skip-pi)
				skip_pi=1
				shift
				;;
			--skip-herdr)
				skip_herdr=1
				shift
				;;
			--skip-nvim)
				skip_nvim=1
				shift
				;;
			-h|--help)
				cat <<EOF
Usage: ${SCRIPT_NAME} update [options]

Options:
  -v, --verbose    Stream full output from every update tool
  --skip-packages  Skip Homebrew/yay updates
  --skip-stow      Skip re-applying stow links
  --skip-pi        Skip pi and extension updates
  --skip-herdr     Skip Herdr update
  --skip-nvim      Skip Neovim Lazy/Mason/Tree-sitter updates
  --help           Show this help
EOF
				return
				;;
			*)
				error "Unknown update option: $1"
				return 1
				;;
		esac
	done

	if [[ $UPDATE_VERBOSE -eq 0 ]]; then
		header "Updating dotfiles"
	fi

	if ! run_update_step repo "Repository" update_repo; then
		failed_steps+=(repository)
	fi
	if [[ $skip_packages -eq 0 ]]; then
		if ! run_update_step packages "OS packages" update_packages; then
			failed_steps+=(packages)
			warn "Package update failed; continuing with remaining update steps"
		fi
	fi

	if [[ $skip_stow -eq 0 ]]; then
		if ! run_update_step stow "Stow links" cmd_stow; then
			failed_steps+=(stow)
			warn "Stow failed; continuing with remaining update steps"
		fi
	fi

	if [[ $skip_nvim -eq 0 ]]; then
		if ! run_update_step nvim "Neovim plugins and tools" update_nvim; then
			failed_steps+=(nvim)
			warn "Neovim update failed; continuing with remaining update steps"
		fi
	fi

	if [[ $skip_pi -eq 0 ]]; then
		if ! run_update_step pi "pi and extensions" update_pi; then
			failed_steps+=(pi)
			warn "pi and extension update failed; continuing with remaining update steps"
		fi
	fi

	if [[ $skip_herdr -eq 0 ]]; then
		if ! run_update_step herdr "Herdr" update_herdr; then
			failed_steps+=(herdr)
			warn "Herdr update failed; continuing with remaining update steps"
		fi
	fi

	if [[ "$OSTYPE" == darwin* && -x "$HOME/.local/bin/theme-mode" ]]; then
		if ! run_update_step theme "macOS theme mode" update_theme; then
			failed_steps+=(theme)
			warn "Could not refresh theme mode"
		fi
	fi

	if [[ ${#failed_steps[@]} -gt 0 ]]; then
		error "Update completed with failed step(s): ${failed_steps[*]}"
		return 1
	fi

	success "Update complete"
}

read_brewfile_packages() {
	local brewfile="$1"
	local kind="$2"

	[[ -f "$brewfile" ]] || return
	awk -v kind="$kind" '
		$1 == kind && match($0, /"[^"]+"/) {
			print substr($0, RSTART + 1, RLENGTH - 2)
		}
	' "$brewfile"
}

cmd_package_list() {
	local target="${1:-all}"
	local brewfile="$DOTFILES_DIR/macos/Brewfile"
	local profile_file profile

	case "$target" in
		all|macos)
			if [[ -f "$brewfile" ]]; then
				header "macOS Brewfile"
				printf "${BOLD}Formulae:${RESET}\n"
				read_brewfile_packages "$brewfile" brew | sed 's/^/  - /'
				printf "\n${BOLD}Casks:${RESET}\n"
				read_brewfile_packages "$brewfile" cask | sed 's/^/  - /'
			else
				warn "Brewfile not found: $brewfile"
			fi
			[[ "$target" == "macos" ]] && return
			;&
		linux)
			header "Linux package profiles"
			for profile_file in "$DOTFILES_DIR"/linux/packages/*.txt; do
				[[ -f "$profile_file" ]] || continue
				profile="${profile_file:t:r}"
				printf "${BOLD}%s:${RESET}\n" "$profile"
				grep -vE '^[[:space:]]*(#|$)' "$profile_file" | sed 's/^/  - /'
				printf '\n'
			done
			;;
		*)
			error "Unknown package list target: $target"
			printf 'Use: %s package list [all|macos|linux]\n' "$SCRIPT_NAME"
			return 1
			;;
	esac
}

cmd_package() {
	local subcommand="${1:-list}"
	[[ $# -gt 0 ]] && shift

	case "$subcommand" in
		list)
			cmd_package_list "$@"
			;;
		-h|--help|help)
			cat <<EOF
Usage: ${SCRIPT_NAME} package COMMAND [args]

Commands:
  list [all|macos|linux]  List tracked package manifests

Package add/remove is intentionally left to the declarative manifests for now:
  macos/Brewfile
  linux/packages/*.txt
EOF
			;;
		*)
			error "Unknown package subcommand: $subcommand"
			return 1
			;;
	esac
}

cmd_check_packages() {
	case "$OSTYPE" in
		darwin*)
			header "Checking macOS packages"
			if ! command_exists brew; then
				error "Homebrew not found"
				return 1
			fi
			brew bundle check --file="$DOTFILES_DIR/macos/Brewfile"
			;;
		linux-gnu*)
			header "Checking Linux packages"
			if ! command_exists pacman; then
				error "pacman not found"
				return 1
			fi

			local profiles=(core-cli core-apps desktop-hyprland)
			local profile profile_file pkg missing=()
			for profile in "${profiles[@]}"; do
				profile_file="$DOTFILES_DIR/linux/packages/$profile.txt"
				[[ -f "$profile_file" ]] || continue
				while IFS= read -r pkg || [[ -n "$pkg" ]]; do
					pkg="${pkg%%#*}"
					pkg="${pkg#${pkg%%[![:space:]]*}}"
					pkg="${pkg%${pkg##*[![:space:]]}}"
					[[ -z "$pkg" ]] && continue
					pacman -Q "$pkg" >/dev/null 2>&1 || missing+=("$pkg")
				done < "$profile_file"
			done

			if [[ ${#missing[@]} -eq 0 ]]; then
				success "Default Linux profile packages are installed"
			else
				warn "Missing packages (${#missing[@]}):"
				printf '  - %s\n' "${missing[@]}"
				return 1
			fi
			;;
		*)
			error "Unsupported OSTYPE: $OSTYPE"
			return 1
			;;
	esac
}

cmd_benchmark_shell() {
	local runs=10
	local verbose=0

	while [[ $# -gt 0 ]]; do
		case "$1" in
			-r|--runs)
				if [[ $# -lt 2 ]]; then
					error "--runs requires a value"
					return 1
				fi
				runs="$2"
				shift 2
				;;
			-v|--verbose)
				verbose=1
				shift
				;;
			-h|--help)
				cat <<EOF
Usage: ${SCRIPT_NAME} benchmark-shell [options]

Options:
  -r, --runs NUM  Number of runs (default: 10)
  -v, --verbose   Print individual timings
  --help          Show this help
EOF
				return
				;;
			*)
				error "Unknown benchmark-shell option: $1"
				return 1
				;;
		esac
	done

	if ! [[ "$runs" =~ '^[0-9]+$' ]] || [[ "$runs" -lt 1 || "$runs" -gt 100 ]]; then
		error "runs must be an integer between 1 and 100"
		return 1
	fi

	if ! command_exists fish; then
		error "fish is not installed"
		return 1
	fi

	if ! command_exists python3; then
		error "python3 is required for benchmarking"
		return 1
	fi

	header "Benchmarking Fish startup"
	python3 - "$runs" "$verbose" <<'PY'
import statistics
import subprocess
import sys
import time

runs = int(sys.argv[1])
verbose = sys.argv[2] == "1"
times = []
for i in range(runs):
    start = time.perf_counter()
    subprocess.run(["fish", "-c", "exit 0"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=True)
    elapsed = time.perf_counter() - start
    times.append(elapsed)
    if verbose:
        print(f"Run {i + 1:02d}: {elapsed * 1000:.1f} ms")

avg = statistics.mean(times)
print(f"Average: {avg * 1000:.1f} ms")
print(f"Fastest: {min(times) * 1000:.1f} ms")
print(f"Slowest: {max(times) * 1000:.1f} ms")
PY
}

cmd_completions() {
	header "Generating Fish completions"

	local completions_dir="$DOTFILES_DIR/common/.config/fish/completions"
	local completions_file="$completions_dir/dot.fish"
	mkdir -p "$completions_dir"

	cat > "$completions_file" <<'EOF'
# Fish shell completions for dot

complete -c dot -f
complete -c dot -n "__fish_use_subcommand" -a "init" -d "Run full machine setup"
complete -c dot -n "__fish_use_subcommand" -a "update" -d "Update repo, packages, Neovim, stow links, pi, Herdr, and pi extensions"
complete -c dot -n "__fish_use_subcommand" -a "stow" -d "Apply stow links"
complete -c dot -n "__fish_use_subcommand" -a "unstow" -d "Remove stow links"
complete -c dot -n "__fish_use_subcommand" -a "doctor" -d "Validate dotfiles health"
complete -c dot -n "__fish_use_subcommand" -a "check-packages" -d "Check package manifest status"
complete -c dot -n "__fish_use_subcommand" -a "package" -d "Package manifest helpers"
complete -c dot -n "__fish_use_subcommand" -a "benchmark-shell" -d "Benchmark Fish startup"
