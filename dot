	success "Generated $completions_file"
	info "Run '${SCRIPT_NAME} stow --only-config fish' or re-run '${SCRIPT_NAME} stow' to link it"
}

main() {
	while [[ $# -gt 0 ]]; do
		case "$1" in
			--version)
				printf '%s version %s\n' "$SCRIPT_NAME" "$VERSION"
				return
				;;
			-h|--help)
				usage
				return
				;;
			*)
				break
				;;
		esac
	done

	local cmd="${1:-help}"
	[[ $# -gt 0 ]] && shift

	case "$cmd" in
		init) cmd_init "$@" ;;
		update) cmd_update "$@" ;;
		stow) cmd_stow "$@" ;;
		unstow) cmd_unstow "$@" ;;
		doctor) cmd_doctor "$@" ;;
		check-packages) cmd_check_packages "$@" ;;
		package) cmd_package "$@" ;;
		benchmark-shell) cmd_benchmark_shell "$@" ;;
		completions) cmd_completions "$@" ;;
		edit) cmd_edit "$@" ;;
		link) cmd_link "$@" ;;
		unlink) cmd_unlink "$@" ;;
		help) usage ;;
		*)
			error "Unknown command: $cmd"
			printf "Run '%s help' for usage.\n" "$SCRIPT_NAME" >&2
			return 1
			;;
	esac
}

main "$@"
