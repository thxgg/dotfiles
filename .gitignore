.DS_Store
.vscode/

# Runtime logs/state
common/.config/btop/btop.log
common/.config/opencode/worktrees/
common/.config/opencode/package-lock.json
common/.config/zed/prompts/
common/.config/atuin/atuin-receipt.json
common/.config/herdr/release-notes.json
common/.config/herdr/session.json
common/.config/herdr/session-history.json
common/.config/herdr/*.log
common/.config/amp/*.amp-write-meta
.claude/settings.local.json

# Agent-generated local/project state
.agents/artifacts/
.pi/artifacts/
.pi/ephemeral.json
.pi/skills/

# Pi global runtime/state: ignore by default, then allowlist portable config.
common/.pi/agent/*
!common/.pi/agent/AGENTS.md
!common/.pi/agent/APPEND_SYSTEM.md
!common/.pi/agent/cloak.json
!common/.pi/agent/extensions/
!common/.pi/agent/extensions/**
!common/.pi/agent/keybindings.json
!common/.pi/agent/npm/
!common/.pi/agent/npm/package.json
!common/.pi/agent/skills/
!common/.pi/agent/skills/**
!common/.pi/agent/themes/
!common/.pi/agent/themes/*.json

# Local env / direnv overrides
common/.env
common/.env.secrets
common/.envrc.local

# Fish runtime state
common/.config/fish/fish_variables

# Generated directories inside stow roots (never commit)
common/.pi/node_modules/

# Pi runtime state (machine-local, never commit or stow)
common/.pi/ephemeral/

# Dependency directories
**/node_modules/

# SSH safety: keep config tracked, ignore private key material
common/.ssh/*
!common/.ssh/config

# Safety guardrails for nested repos
common/.config/nvim/.git/
common/.config/opencode/.git/

# MCP artifacts
.playwright-mcp/

# Private local documentation
docs/private/
