.DS_Store
.vscode/

# Runtime logs/state
common/.config/btop/btop.log
common/.config/opencode/worktrees/
common/.config/opencode/package-lock.json
common/.config/zed/prompts/
common/.config/atuin/atuin-receipt.json
common/.config/herdr/release-notes.json
common/.config/herdr/session.json
common/.config/herdr/session-history.json
common/.config/herdr/*.log
.claude/settings.local.json

# Pi local state
.pi/todos/
.pi/ephemeral.json
.pi/skills/
common/.pi/agent/sessions/

# Local env / direnv overrides
common/.env
common/.env.secrets
common/.envrc.local

# Fish runtime state
common/.config/fish/fish_variables

# Generated directories inside stow roots (never commit)
common/.pi/node_modules/

# Pi runtime state (machine-local, never commit or stow)
common/.pi/agent/sessions/
common/.pi/agent/.cache/
common/.pi/agent/auth.json
common/.pi/agent/mcp-cache.json
common/.pi/agent/mcp-npx-cache.json
common/.pi/ephemeral/

# Dependency directories
**/node_modules/

# SSH safety: keep config tracked, ignore private key material
common/.ssh/*
!common/.ssh/config

# Safety guardrails for nested repos
common/.config/nvim/.git/
common/.config/opencode/.git/

# MCP artifacts
.playwright-mcp/
