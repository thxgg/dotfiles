{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "shortcut": {
      "command": "npx",
      "args": ["-y", "@shortcut/mcp@latest"],
      "env": {
        "SHORTCUT_API_TOKEN": "${SHORTCUT_API_TOKEN}"
      }
    },
    "db_staging": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "--network=host",
        "-e",
        "DATABASE_URI",
        "crystaldba/postgres-mcp",
        "--access-mode=unrestricted"
      ],
      "env": {
        "DATABASE_URI": "${DATABASE_URI_STAGING}"
      },
      "lifecycle": "lazy"
    },
    "db_prod": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "--network=host",
        "-e",
        "DATABASE_URI",
        "crystaldba/postgres-mcp",
        "--access-mode=unrestricted"
      ],
      "env": {
        "DATABASE_URI": "${DATABASE_URI_PROD}"
      },
      "lifecycle": "lazy"
    },
    "heroku": {
      "command": "heroku",
      "args": ["mcp:start"],
      "lifecycle": "lazy"
    },
    "aws-mcp": {
      "command": "uvx",
      "args": [
        "mcp-proxy-for-aws@latest",
        "https://aws-mcp.us-east-1.api.aws/mcp",
        "--profile",
        "code",
        "--metadata",
        "AWS_REGION=eu-west-2"
      ],
      "lifecycle": "lazy"
    },
    "stripe": {
      "url": "https://mcp.stripe.com",
      "auth": "oauth",
      "lifecycle": "lazy"
    },
    "stripe-business": {
      "url": "https://mcp.stripe.com",
      "auth": "oauth",
      "lifecycle": "lazy"
    },
    "stripe-business-prod": {
      "url": "https://mcp.stripe.com",
      "auth": "oauth",
      "lifecycle": "lazy"
    },
    "stripe-memberships": {
      "url": "https://mcp.stripe.com",
      "auth": "oauth",
      "lifecycle": "lazy"
    },
    "stripe-memberships-prod": {
      "url": "https://mcp.stripe.com",
      "auth": "oauth",
      "lifecycle": "lazy"
    }
  }
}
