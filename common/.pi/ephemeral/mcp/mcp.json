{
  "mcpServers": {
    "linear": {
      "url": "https://mcp.linear.app/mcp",
      "idleTimeout": 10
    },
    "betterstack": {
      "url": "https://mcp.betterstack.com"
    },
    "db_staging": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "--network=host",
        "-e",
        "DATABASE_URI",
        "crystaldba/postgres-mcp",
        "--access-mode=unrestricted"
      ],
      "env": {
        "DATABASE_URI": "${DATABASE_URI_STAGING}"
      },
      "idleTimeout": 2
    },
    "db_prod": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "--network=host",
        "-e",
        "DATABASE_URI",
        "crystaldba/postgres-mcp",
        "--access-mode=unrestricted"
      ],
      "env": {
        "DATABASE_URI": "${DATABASE_URI_PROD}"
      },
      "idleTimeout": 2
    },
    "stripe-business": {
      "url": "https://mcp.stripe.com"
    },
    "sonarqube": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "SONARQUBE_TOKEN",
        "-e",
        "SONARQUBE_URL",
        "mcp/sonarqube"
      ],
      "env": {
        "SONARQUBE_TOKEN": "${SONARQUBE_TOKEN}",
        "SONARQUBE_URL": "https://sonarcloud.io"
      },
      "idleTimeout": 2
    },
    "heroku": {
      "command": "heroku",
      "args": [
        "mcp:start"
      ],
      "idleTimeout": 3
    },
    "hubspot_staging": {
      "command": "npx",
      "args": [
        "-y",
        "@hubspot/mcp-server"
      ],
      "env": {
        "PRIVATE_APP_ACCESS_TOKEN": "${HUBSPOT_PRIVATE_APP_ACCESS_TOKEN_STAGING}"
      },
      "idleTimeout": 3
    },
    "hubspot_prod": {
      "command": "npx",
      "args": [
        "-y",
        "@hubspot/mcp-server"
      ],
      "env": {
        "PRIVATE_APP_ACCESS_TOKEN": "${HUBSPOT_PRIVATE_APP_ACCESS_TOKEN_PROD}"
      },
      "idleTimeout": 3
    },
    "aws-mcp": {
      "command": "uvx",
      "args": [
        "mcp-proxy-for-aws@latest",
        "https://aws-mcp.us-east-1.api.aws/mcp",
        "--profile",
        "code",
        "--metadata",
        "AWS_REGION=eu-west-2"
      ],
      "idleTimeout": 3
    },
    "stripe-business-prod": {
      "url": "https://mcp.stripe.com"
    },
    "stripe-memberships": {
      "url": "https://mcp.stripe.com"
    },
    "stripe-memberships-prod": {
      "url": "https://mcp.stripe.com"
    }
  }
}
