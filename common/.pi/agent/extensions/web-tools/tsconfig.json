{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "./index.ts",
    "./settings.ts",
    "./result.ts",
    "./redacted.ts",
    "./types.ts",
    "./webfetch-input.ts",
    "./websearch-input.ts",
    "./fetch-page.ts",
    "./search-web.ts",
    "./vendor.d.ts",
    "./public-web-client.ts",
    "./network.ts",
    "./html.ts",
    "./truncation.ts",
    "./temp.ts",
    "./render.ts",
    "./tool-output.ts",
    "./webfetch.ts",
    "./websearch.ts",
    "./providers/**/*.ts",
    "./test/**/*.ts"
  ]
}
