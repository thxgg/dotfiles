{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "./index.ts",
    "./types.ts",
    "./validation.ts",
    "./client.ts",
    "./artifacts.ts",
    "./test/**/*.ts"
  ]
}
