{
  "mcpServers": {
    "context7": {
      "url": "https://mcp.context7.com/mcp",
      "lifecycle": "eager"
    },
    "grep_app": {
      "url": "https://mcp.grep.app/",
      "lifecycle": "eager"
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "shortcut": {
      "command": "npx",
      "args": ["-y", "@shortcut/mcp@latest"],
      "env": {
        "SHORTCUT_API_TOKEN": "${SHORTCUT_API_TOKEN}"
      }
    }
  }
}
