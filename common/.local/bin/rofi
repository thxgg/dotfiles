#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" >/dev/null 2>&1 && pwd)"
# shellcheck source=/dev/null
. "$SCRIPT_DIR/theme-lib.sh"

for arg in "$@"; do
  case "$arg" in
    -theme|--theme)
      theme_exec_real rofi "$@"
      ;;
  esac
done

mode="$(theme_current_mode)"
theme_path="$HOME/.config/rofi/cloudflare-$mode.rasi"
if [[ ! -f "$theme_path" ]]; then
  theme_exec_real rofi "$@"
fi

theme_exec_real rofi -theme "$theme_path" "$@"
