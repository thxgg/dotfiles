#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" >/dev/null 2>&1 && pwd)"
# shellcheck source=/dev/null
. "$SCRIPT_DIR/theme-lib.sh"

quiet=0
session_init=0
force=0

usage() {
  cat <<'EOF'
Usage: theme-mode [--quiet] [--session-init] [--force] <get|get-configured|set|toggle|apply> [auto|dark|light]

Commands:
  get             Print the resolved theme mode (dark/light)
  get-configured  Print the configured mode (auto/dark/light)
  set <mode>      Persist mode and apply it; use auto on macOS to follow system appearance
  toggle          Switch between resolved dark and light, then apply it
  apply [mode]    Apply configured mode, or supplied auto/dark/light, without toggling

Flags:
  --quiet         Suppress status logging
  --session-init  Only materialize state and settings needed for session startup;
                  skip live Hyprland reloads and HyprPanel restarts
  --force         Reapply even when the resolved mode has not changed
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --quiet)
      quiet=1
      shift
      ;;
    --session-init)
      session_init=1
      shift
      ;;
    --force)
      force=1
      shift
      ;;
    *)
      break
      ;;
  esac
done

command_name="${1:-get}"
shift || true

log() {
  [[ $quiet -eq 1 ]] && return 0
  printf '%s\n' "$*"
}

valid_configured_mode() {
  [[ "${1:-}" == auto || "${1:-}" == dark || "${1:-}" == light ]]
}

write_mode() {
  local mode="$1"
  theme_ensure_state_dir
  printf '%s\n' "$mode" > "$(theme_mode_file)"
}

write_last_applied_mode() {
  local mode="$1"
  theme_ensure_state_dir
  printf '%s\n' "$mode" > "$(theme_last_applied_mode_file)"
}

last_applied_mode() {
  local file
  file="$(theme_last_applied_mode_file)"
  if [[ -r "$file" ]]; then
    tr -d '[:space:]' < "$file"
  fi
}

setup_kvantum_runtime_theme() {
  local mode="$1"
  local data_home runtime_theme_dir source_dir source_theme source_root
  local source_config source_svg

  data_home="${XDG_DATA_HOME:-$HOME/.local/share}"
  runtime_theme_dir="$data_home/themes/catppuccin-current/Kvantum"

  if [[ "$mode" == light ]]; then
    source_theme="catppuccin-latte-lavender"
  else
    source_theme="catppuccin-mocha-lavender"
  fi

  source_dir=""
  source_config=""
  source_svg=""
  for source_root in /usr/share/Kvantum "$data_home/Kvantum" "$HOME/.config/Kvantum"; do
    [[ -d "$source_root" ]] || continue
    source_dir="$(find "$source_root" -mindepth 1 -maxdepth 1 -type d -iname "$source_theme" -print -quit 2>/dev/null)"
    [[ -n "$source_dir" ]] || continue

    source_config="$(find "$source_dir" -maxdepth 1 -type f -iname '*.kvconfig' -print -quit 2>/dev/null)"
    source_svg="$(find "$source_dir" -maxdepth 1 -type f -iname '*.svg' -print -quit 2>/dev/null)"
    if [[ -n "$source_config" && -n "$source_svg" ]]; then
      break
    fi

    source_dir=""
  done

  if [[ -z "$source_dir" || -z "$source_config" || -z "$source_svg" ]]; then
    return 0
  fi

  mkdir -p "$runtime_theme_dir"
  ln -sfn "$source_config" "$runtime_theme_dir/catppuccin-current.kvconfig"
  ln -sfn "$source_svg" "$runtime_theme_dir/catppuccin-current.svg"
}

gtk_theme_exists() {
  local theme_name="$1"
  [[ -d "/usr/share/themes/$theme_name" || \
     -d "$HOME/.themes/$theme_name" || \
     -d "${XDG_DATA_HOME:-$HOME/.local/share}/themes/$theme_name" ]]
}

select_gtk_theme() {
  local mode="$1"
  local candidate
  local -a candidates

  if [[ "$mode" == dark ]]; then
    candidates=(
      catppuccin-mocha-lavender-standard+default
      catppuccin-mocha-blue-standard+default
      Adwaita-dark
    )
  else
    candidates=(
      catppuccin-latte-lavender-standard+default
      Adwaita
    )
  fi

  for candidate in "${candidates[@]}"; do
    if gtk_theme_exists "$candidate"; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done
}

apply_gtk_settings_files() {
  local mode="$1"
  local gtk_theme="$2"
  local config_home prefer_dark gtk_dir settings_file

  config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
  if [[ "$mode" == dark ]]; then
    prefer_dark=1
  else
    prefer_dark=0
  fi

  for gtk_dir in "$config_home/gtk-3.0" "$config_home/gtk-4.0"; do
    mkdir -p "$gtk_dir"
    settings_file="$gtk_dir/settings.ini"
    {
      printf '[Settings]\n'
      if [[ -n "$gtk_theme" ]]; then
        printf 'gtk-theme-name=%s\n' "$gtk_theme"
      fi
      printf 'gtk-application-prefer-dark-theme=%s\n' "$prefer_dark"
    } > "$settings_file"
  done
}

apply_gtk_preference() {
  local mode="$1"
  local gtk_theme

  gtk_theme="$(select_gtk_theme "$mode" || true)"

  if command -v gsettings >/dev/null 2>&1; then
    gsettings set org.gnome.desktop.interface color-scheme "prefer-$mode" >/dev/null 2>&1 || true
    if [[ -n "$gtk_theme" ]]; then
      gsettings set org.gnome.desktop.interface gtk-theme "$gtk_theme" >/dev/null 2>&1 || true
    fi
  fi

  apply_gtk_settings_files "$mode" "$gtk_theme"
}

apply_helium_preference() {
  local mode="$1"
  local config_home flags_file tmp_file

  # Helium's Arch wrapper reads this file on startup. Keep our theme flag in a
  # managed block so user-defined Helium flags can coexist in the same file.
  if [[ "$(uname -s 2>/dev/null || true)" != Linux ]]; then
    return 0
  fi

  if ! command -v helium-browser >/dev/null 2>&1; then
    return 0
  fi

  config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
  flags_file="$config_home/helium-browser-flags.conf"
  mkdir -p "$config_home"
  tmp_file="$(mktemp)"

  if [[ -r "$flags_file" ]]; then
    awk '
      /^# BEGIN dotfiles theme-mode$/ { skip = 1; next }
      /^# END dotfiles theme-mode$/ { skip = 0; next }
      !skip { print }
    ' "$flags_file" > "$tmp_file"
  fi

  {
    cat "$tmp_file"
    if [[ -s "$tmp_file" ]]; then
      printf '\n'
    fi
    printf '# BEGIN dotfiles theme-mode\n'
    if [[ "$mode" == dark ]]; then
      printf '%s\n' '--force-dark-mode'
    else
      printf '# Light mode: no Helium dark-mode flag.\n'
    fi
    printf '# END dotfiles theme-mode\n'
  } > "$flags_file"

  rm -f "$tmp_file"
}

apply_wallpaper() {
  local mode="$1"
  local config_home wallpaper target client daemon

  if [[ "$(uname -s 2>/dev/null || true)" != Linux ]]; then
    return 0
  fi

  if [[ -z "${WAYLAND_DISPLAY:-}" ]]; then
    return 0
  fi

  config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
  wallpaper="$config_home/background-$mode.png"
  target="$config_home/background"

  if [[ ! -f "$wallpaper" ]]; then
    return 0
  fi

  ln -sfn "$wallpaper" "$target"

  if command -v swww >/dev/null 2>&1; then
    client=swww
    daemon=swww-daemon
  elif command -v awww >/dev/null 2>&1; then
    client=awww
    daemon=awww-daemon
  else
    return 0
  fi

  if ! "$client" query >/dev/null 2>&1 && command -v "$daemon" >/dev/null 2>&1; then
    if [[ "$client" == awww ]]; then
      rm -f "/run/user/$(id -u)/${WAYLAND_DISPLAY}-awww-daemon.sock"
    fi
    nohup "$daemon" >/dev/null 2>&1 &
    sleep 0.3
  fi

  "$client" img "$target" --transition-type fade >/dev/null 2>&1 || \
    "$client" img "$target" >/dev/null 2>&1 || true
}

reload_tmux() {
  if command -v tmux >/dev/null 2>&1 && tmux ls >/dev/null 2>&1; then
    tmux source-file "$HOME/.config/tmux/tmux.conf" >/dev/null 2>&1 || true
  fi
}

apply_fish_colors() {
  local mode="$1"

  if ! command -v fish >/dev/null 2>&1; then
    return 0
  fi

  THEME_MODE="$mode" fish <<'FISH' >/dev/null 2>&1 || true
set mode $THEME_MODE
if test "$mode" = light
    set -U fish_color_normal 4c4f69
    set -U fish_color_command 1e66f5
    set -U fish_color_keyword 7287fd
    set -U fish_color_quote 40a02b
    set -U fish_color_redirection ea76cb
    set -U fish_color_end fe640b
    set -U fish_color_error d20f39 --bold
    set -U fish_color_param 4c4f69
    set -U fish_color_valid_path 1e66f5 --underline
    set -U fish_color_option 179299
    set -U fish_color_comment 8c8fa1
    set -U fish_color_operator 7287fd
    set -U fish_color_escape fe640b
    set -U fish_color_autosuggestion 9ca0b0
    set -U fish_color_selection --background=ccd0da
    set -U fish_color_search_match --background=bcc0cc
    set -U fish_pager_color_completion 4c4f69
    set -U fish_pager_color_description 7c7f93
    set -U fish_pager_color_prefix 7287fd --bold
    set -U fish_pager_color_progress 8c8fa1
    set -U fish_pager_color_selected_background --background=ccd0da
    set -U fish_pager_color_selected_completion 4c4f69
    set -U fish_pager_color_selected_description 6c6f85
else
    set -U fish_color_normal cdd6f4
    set -U fish_color_command 89b4fa
    set -U fish_color_keyword b4befe
    set -U fish_color_quote a6e3a1
    set -U fish_color_redirection f5c2e7
    set -U fish_color_end fab387
    set -U fish_color_error f38ba8 --bold
    set -U fish_color_param cdd6f4
    set -U fish_color_valid_path 89b4fa --underline
    set -U fish_color_option 94e2d5
    set -U fish_color_comment 6c7086
    set -U fish_color_operator b4befe
    set -U fish_color_escape fab387
    set -U fish_color_autosuggestion 585b70
    set -U fish_color_selection --background=313244
    set -U fish_color_search_match --background=45475a
    set -U fish_pager_color_completion cdd6f4
    set -U fish_pager_color_description 9399b2
    set -U fish_pager_color_prefix b4befe --bold
    set -U fish_pager_color_progress 7f849c
    set -U fish_pager_color_selected_background --background=313244
    set -U fish_pager_color_selected_completion cdd6f4
    set -U fish_pager_color_selected_description bac2de
end
FISH
}

reload_hyprland() {
  if command -v hyprctl >/dev/null 2>&1 && hyprctl version >/dev/null 2>&1; then
    hyprctl reload >/dev/null 2>&1 || true
  fi
}

restart_hyprpanel() {
  local start_script="$HOME/.config/hypr/scripts/start-hyprpanel.sh"

  if [[ ! -x "$start_script" ]]; then
    return 0
  fi

  if [[ -z "${WAYLAND_DISPLAY:-}" && -z "${DISPLAY:-}" ]]; then
    return 0
  fi

  if command -v hyprpanel >/dev/null 2>&1; then
    hyprpanel -q -i hyprpanel >/dev/null 2>&1 || hyprpanel -q >/dev/null 2>&1 || true
  fi

  nohup "$start_script" >/dev/null 2>&1 &
}

apply_mode() {
  local resolved_mode="$1"
  local previous_mode
  previous_mode="$(last_applied_mode || true)"

  if [[ $force -eq 0 && "$previous_mode" == "$resolved_mode" ]]; then
    setup_kvantum_runtime_theme "$resolved_mode"
    apply_gtk_preference "$resolved_mode"
    apply_helium_preference "$resolved_mode"
    apply_wallpaper "$resolved_mode"

    log "Theme mode already $resolved_mode"
    if [[ $quiet -eq 0 ]]; then
      printf '%s\n' "$resolved_mode"
    fi
    return 0
  fi

  setup_kvantum_runtime_theme "$resolved_mode"
  apply_gtk_preference "$resolved_mode"
  apply_helium_preference "$resolved_mode"
  apply_wallpaper "$resolved_mode"
  apply_fish_colors "$resolved_mode"
  reload_tmux

  if [[ $session_init -eq 0 ]]; then
    reload_hyprland
    restart_hyprpanel
  fi

  write_last_applied_mode "$resolved_mode"

  log "Applied $resolved_mode theme mode"
  if [[ $quiet -eq 0 ]]; then
    printf '%s\n' "$resolved_mode"
  fi
}

case "$command_name" in
  get)
    theme_current_mode
    ;;
  get-configured)
    theme_configured_mode
    ;;
  set)
    mode="${1:-}"
    if ! valid_configured_mode "$mode"; then
      usage >&2
      exit 1
    fi
    write_mode "$mode"
    force=1
    apply_mode "$(theme_resolve_mode "$mode")"
    ;;
  toggle)
    current_mode="$(theme_current_mode)"
    if [[ "$current_mode" == dark ]]; then
      next_mode=light
    else
      next_mode=dark
    fi
    write_mode "$next_mode"
    force=1
    apply_mode "$next_mode"
    ;;
  apply)
    mode="${1:-$(theme_configured_mode)}"
    if ! valid_configured_mode "$mode"; then
      usage >&2
      exit 1
    fi
    write_mode "$mode"
    apply_mode "$(theme_resolve_mode "$mode")"
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
