#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" >/dev/null 2>&1 && pwd)"
# shellcheck source=/dev/null
. "$SCRIPT_DIR/theme-lib.sh"

quiet=0
session_init=0

usage() {
  cat <<'EOF'
Usage: theme-mode [--quiet] [--session-init] <get|set|toggle|apply> [dark|light]

Commands:
  get            Print the current theme mode (dark/light)
  set <mode>     Persist mode and apply it
  toggle         Switch between dark and light, then apply it
  apply [mode]   Apply the current mode (or the supplied mode) without toggling

Flags:
  --quiet         Suppress status logging
  --session-init  Only materialize state and settings needed for session startup;
                  skip live Hyprland reloads and HyprPanel restarts
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --quiet)
      quiet=1
      shift
      ;;
    --session-init)
      session_init=1
      shift
      ;;
    *)
      break
      ;;
  esac
done

command_name="${1:-get}"
shift || true

log() {
  [[ $quiet -eq 1 ]] && return 0
  printf '%s\n' "$*"
}

write_mode() {
  local mode="$1"
  theme_ensure_state_dir
  printf '%s\n' "$mode" > "$(theme_mode_file)"
}

setup_kvantum_runtime_theme() {
  local mode="$1"
  local data_home runtime_theme_dir source_dir

  data_home="${XDG_DATA_HOME:-$HOME/.local/share}"
  runtime_theme_dir="$data_home/themes/cloudflare-current/Kvantum"
  source_dir="$HOME/.config/Kvantum/cloudflare-$mode"

  if [[ ! -f "$source_dir/cloudflare-$mode.kvconfig" || ! -f "$source_dir/cloudflare-$mode.svg" ]]; then
    return 0
  fi

  mkdir -p "$runtime_theme_dir"
  ln -sfn "$source_dir/cloudflare-$mode.kvconfig" "$runtime_theme_dir/cloudflare-current.kvconfig"
  ln -sfn "$source_dir/cloudflare-$mode.svg" "$runtime_theme_dir/cloudflare-current.svg"
}

apply_gtk_preference() {
  local mode="$1"

  if command -v gsettings >/dev/null 2>&1; then
    gsettings set org.gnome.desktop.interface color-scheme "prefer-$mode" >/dev/null 2>&1 || true
  fi
}

reload_tmux() {
  if command -v tmux >/dev/null 2>&1 && tmux ls >/dev/null 2>&1; then
    tmux source-file "$HOME/.config/tmux/tmux.conf" >/dev/null 2>&1 || true
  fi
}

reload_hyprland() {
  if command -v hyprctl >/dev/null 2>&1 && hyprctl version >/dev/null 2>&1; then
    hyprctl reload >/dev/null 2>&1 || true
  fi
}

restart_hyprpanel() {
  local start_script="$HOME/.config/hypr/scripts/start-hyprpanel.sh"

  if [[ ! -x "$start_script" ]]; then
    return 0
  fi

  if [[ -z "${WAYLAND_DISPLAY:-}" && -z "${DISPLAY:-}" ]]; then
    return 0
  fi

  if command -v hyprpanel >/dev/null 2>&1; then
    hyprpanel -q -i hyprpanel >/dev/null 2>&1 || hyprpanel -q >/dev/null 2>&1 || true
  fi

  nohup "$start_script" >/dev/null 2>&1 &
}

apply_mode() {
  local mode="$1"

  setup_kvantum_runtime_theme "$mode"
  apply_gtk_preference "$mode"
  reload_tmux

  if [[ $session_init -eq 0 ]]; then
    reload_hyprland
    restart_hyprpanel
  fi

  log "Applied $mode theme mode"
  if [[ $quiet -eq 0 ]]; then
    printf '%s\n' "$mode"
  fi
}

case "$command_name" in
  get)
    theme_current_mode
    ;;
  set)
    mode="${1:-}"
    if [[ "$mode" != dark && "$mode" != light ]]; then
      usage >&2
      exit 1
    fi
    write_mode "$mode"
    apply_mode "$mode"
    ;;
  toggle)
    current_mode="$(theme_current_mode)"
    if [[ "$current_mode" == dark ]]; then
      next_mode=light
    else
      next_mode=dark
    fi
    write_mode "$next_mode"
    apply_mode "$next_mode"
    ;;
  apply)
    mode="${1:-$(theme_current_mode)}"
    if [[ "$mode" != dark && "$mode" != light ]]; then
      usage >&2
      exit 1
    fi
    write_mode "$mode"
    apply_mode "$mode"
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
