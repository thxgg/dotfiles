{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "exa": {
            "type": "remote",
            "url": "https://mcp.exa.ai/mcp",
            "enabled": true
        },
        "opensrc": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "opensrc-mcp"
            ],
            "enabled": true
        },
        "playwright": {
            "type": "local",
            "command": [
                "npx",
                "@playwright/mcp@latest"
            ],
            "enabled": false
        },
        "figma": {
            "type": "remote",
            "url": "https://mcp.figma.com/mcp",
            "enabled": false
        },
        "github": {
            "type": "local",
            "command": [
                "docker",
                "run",
                "-i",
                "--rm",
                "-e",
                "GITHUB_PERSONAL_ACCESS_TOKEN",
                "ghcr.io/github/github-mcp-server"
            ],
            "environment": {
                "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_PAT}"
            },
            "enabled": true
        },
        "overseer": {
            "type": "local",
            "command": ["npx", "-y", "@dmmulroy/overseer@0.11.0", "mcp"],
            "environment": {
                "OVERSEER_DB_PATH": "{env:HOME}/.local/share/opencode/overseer/tasks.db"
            },
            "enabled": false
        },
        "steward": {
            "type": "local",
            "command": ["npx", "-y", "@thxgg/steward", "mcp"],
            "enabled": true
        }
    },
    "agent": {
        "plan": {
            "mode": "primary",
            "model": "anthropic/claude-opus-4-6",
            "variant": "max",
            "tools": {
                "write": false,
                "edit": false,
                "bash": true,
            }
        },
        "build": {
            "mode": "primary",
            "model": "anthropic/claude-opus-4-6",
            "variant": "max",
            "tools": {
                "write": true,
                "edit": true,
                "bash": true
            }
        },
        "deep": {
            "mode": "primary",
            "model": "openai/gpt-5.4",
            "variant": "xhigh",
            "tools": {
                "write": true,
                "edit": true,
                "bash": true
            }
        }
    },
    "permission": {
        "webfetch": "allow",
        "doom_loop": "ask",
        "read": {
            "*": "allow",
            "*.env": "deny",
            "*.env.*": "deny",
            "*.envrc": "deny",
            "*.dev.vars": "deny",
            "*.env.example": "allow",
            "secrets/*": "deny",
            "~/.local/share/opencode/mcp-auth.json": "deny"
        },
        "edit": {
            "*": "allow"
        },
        "external_directory": {
            "*": "ask",
            "~/Projects/**": "allow",
            "~/.config/**": "allow",
            "~/Projects/Personal/dotfiles/**": "allow",
            "/tmp/**": "allow",
            "/private/tmp/**": "allow"
        },
        "bash": {
            "*": "ask",
            // Git - simplified to match dmmulroy's approach
            "git *": "allow",
            "git push*": "ask",
            "git reset --hard *": "deny",
            "git push --force *": "deny",
            // jj (jujutsu) - matching dmmulroy's approach
            "jj *": "allow",
            "jj git push*": "ask",
            "jj gp*": "ask",
            // GitHub CLI - read operations
            "gh *": "allow",
            "gh * approve*": "ask",
            "gh * close*": "ask",
            "gh * comment*": "ask",
            "gh * create*": "ask",
            "gh * delete*": "ask",
            "gh * edit*": "ask",
            "gh * merge*": "ask",
            "gh * reopen*": "ask",
            "gh * review*": "ask",
            "gh repo clone*": "allow",
            // GitLab CLI
            "glab *": "allow",
            "glab * approve*": "ask",
            "glab * close*": "ask",
            "glab * comment*": "ask",
            "glab * create*": "ask",
            "glab * delete*": "ask",
            "glab * edit*": "ask",
            "glab * merge*": "ask",
            "glab * reopen*": "ask",
            "glab * review*": "ask",
            "glab repo clone*": "allow",
            // File operations
            "ls *": "allow",
            "cat *": "allow",
            "head *": "allow",
            "tail *": "allow",
            "find *": "allow",
            "fd *": "allow",
            "rg *": "allow",
            "grep *": "allow",
            "readlink *": "allow",
            "realpath *": "allow",
            "basename *": "allow",
            "dirname *": "allow",
            "file *": "allow",
            "stat *": "allow",
            "du *": "allow",
            // Text processing
            "sort *": "allow",
            "uniq *": "allow",
            "wc *": "allow",
            "cut *": "allow",
            "awk *": "allow",
            "gsed *": "allow",
            "sed *": "allow",
            "tr *": "allow",
            "xargs *": "ask",
            "tee *": "allow",
            "diff *": "allow",
            "paste *": "allow",
            "column *": "allow",
            // Archive/compression
            "tar *": "allow",
            "zip *": "allow",
            "unzip *": "allow",
            "gzip *": "allow",
            "gunzip *": "allow",
            // System info
            "which *": "allow",
            "type *": "allow",
            "uname *": "allow",
            "hostname": "allow",
            "whoami": "allow",
            "id": "allow",
            "date *": "allow",
            "pwd": "allow",
            "echo *": "allow",
            "printf *": "allow",
            "true": "allow",
            // File manipulation
            "mkdir *": "allow",
            "cp *": "allow",
            "mv *": "allow",
            "touch *": "allow",
            "rm *": "ask",
            "rm -rf *": "deny",
            // Package managers
            "npm *": "allow",
            "npx *": "allow",
            "pnpm *": "allow",
            "yarn *": "allow",
            "bun *": "allow",
            "pip *": "allow",
            "pip3 *": "allow",
            "pipx *": "allow",
            "uv *": "allow",
            // Language runtimes/compilers
            "node *": "allow",
            "go *": "allow",
            "cargo *": "allow",
            "rustc *": "allow",
            "python *": "allow",
            "python3 *": "allow",
            "ruby *": "allow",
            "tsc *": "allow",
            "turbo *": "allow",
            "vite *": "allow",
            "vitest *": "allow",
            // Build tools
            "./gradlew *": "allow",
            "make *": "allow",
            "cmake *": "allow",
            // Linters/formatters
            "prettier *": "allow",
            "biome *": "allow",
            "stylua *": "allow",
            "ruff *": "allow",
            "shellcheck *": "allow",
            "cloc *": "allow",
            // JSON/Query
            "jq *": "allow",
            "ast-grep *": "allow",
            "doggo *": "allow",
            // Navigation
            "z *": "allow",
            "zoxide *": "allow",
            "fzf *": "allow",
            // Tools
            "tree *": "allow",
            "stow *": "allow",
            "tmux *": "allow",
            "nvim *": "allow",
            "bat *": "allow",
            "delta *": "allow",
            // macOS utilities
            "open *": "allow",
            "pbcopy": "allow",
            "pbpaste": "allow",
            "source *": "allow",
            // Network
            "curl *": "allow",
            "wget *": "allow",
            "websocat *": "allow",
            "nmap *": "ask",
            // Node version management
            "fnm *": "allow",
            // dot command
            "dot *": "allow",
            // Process management
            "lsof *": "allow",
            "kill *": "ask"
        },
    },
    "plugin": ["opencode-anthropic-oauth"]
}
