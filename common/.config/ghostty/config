font-family = Berkeley Mono Variable Nerd Font
# TODO(upstream): remove this forced dark theme once Ghostty/portal
# light/dark detection is patched; restore the light:...,dark:... theme pair.
theme = Catppuccin Mocha
window-theme = system
font-size = 14
adjust-cell-height = -1
adjust-font-baseline = 1
# macos-titlebar-style = hidden
quit-after-last-window-closed = true
maximize = true
shell-integration = fish
unfocused-split-opacity = 0.97
macos-option-as-alt = true
macos-titlebar-proxy-icon = hidden
clipboard-read = allow
clipboard-write = allow
title = ghostty
env = TMPDIR=/home/thxgg/.local/state/tmp
env = PI_SKIP_TMUX_AUTOSTART=1
window-padding-y = 0
window-padding-color = extend
